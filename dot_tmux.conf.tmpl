# ~/.tmux.conf
# Managed by chezmoi — do not edit directly

# Use system zsh, resolved at chezmoi apply for cross-platform
set -g default-shell {{ output "which" "zsh" | trim }}

# Smart pane navigation with vim splits using C-hjkl
# Requires christoomey/vim-tmux-navigator in vim
is_vim="ps -o state= -o comm= -t '#{pane_tty}' \
     | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|n?vim?x?)(diff)?$'"
bind-key -n C-h if-shell "$is_vim" "send-keys C-h" "select-pane -L"
bind-key -n C-j if-shell "$is_vim" "send-keys C-j" "select-pane -D"
bind-key -n C-k if-shell "$is_vim" "send-keys C-k" "select-pane -U"
bind-key -n C-l if-shell "$is_vim" "send-keys C-l" "select-pane -R"
bind-key -n 'C-\' if-shell "$is_vim" "send-keys C-\\" "select-pane -l"
bind-key -T copy-mode-vi C-h select-pane -L
bind-key -T copy-mode-vi C-j select-pane -D
bind-key -T copy-mode-vi C-k select-pane -U
bind-key -T copy-mode-vi C-l select-pane -R
bind-key -T copy-mode-vi 'C-\' select-pane -l

# Vi keys in copy mode: prefix+[ to enter, v to select, y to copy
set -g mode-keys vi

# OSC 52 passthrough so apps inside tmux can write to system clip
set -g set-clipboard on

# Open panes and windows in cwd
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Start numbering at 1, not 0; renumber on close
set -g base-index 1
set-window-option -g pane-base-index 1
set -g renumber-windows on

# Status bar, nice light gray/green
set -g status-bg '#333333'
set -g status-fg '#88ff88'
set -g status-position top

# Mouse to focus and copy
set -g mouse on

{{ if not .minimal -}}
# Plugins managed by TPM (tmux plugin manager)
# First install: git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
# prefix+I to install, prefix+U to update, prefix+alt+u to remove
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-yank'      # copies to system clipboard

{{ if eq .chezmoi.os "darwin" -}}
set-environment -g PATH "/opt/homebrew/bin:/bin:/usr/bin"
{{ end -}}
run '~/.tmux/plugins/tpm/tpm'
{{ end -}}

# Local overrides
if-shell "[ -f ~/.tmux.conf.local ]" 'source ~/.tmux.conf.local'
